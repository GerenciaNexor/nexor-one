{
  "compilerOptions": {
    "target":                     "ES2022",
    "module":                     "commonjs",
    "lib":                        ["ES2022", "DOM"],
    "types":                      ["node"],
    "strict":                     true,
    "esModuleInterop":            true,
    "skipLibCheck":               true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":          true,
    "outDir":                     "dist",
    "baseUrl":                    "."
  },
  "include":  ["**/*.ts"],
  "exclude":  ["node_modules", "dist", "playwright-report", "test-results"]
}
