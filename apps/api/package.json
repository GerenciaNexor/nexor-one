{
  "name": "@nexor/api",
  "version": "0.0.1",
  "private": true,
  "description": "Backend Fastify de NEXOR",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsup src/app.ts --outDir dist --format cjs --no-splitting",
    "start": "npx prisma migrate deploy && node dist/app.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "prisma migrate dev",
    "db:setup": "prisma migrate dev && tsx prisma/setup-rls.ts && prisma db seed",
    "db:reset": "prisma migrate reset --force && tsx prisma/setup-rls.ts && prisma db seed",
    "db:seed": "prisma db seed",
    "db:seed-e2e": "tsx prisma/seed-e2e.ts",
    "db:seed:staging": "tsx prisma/seed-staging.ts",
    "db:rls": "tsx prisma/setup-rls.ts",
    "db:studio": "prisma studio",
    "db:backup": "bash ../../scripts/db-backup.sh",
    "db:restore": "bash ../../scripts/db-restore.sh",
    "prisma:generate": "prisma generate",
    "onboarding": "tsx prisma/onboarding.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@bull-board/api": "^5.23.0",
    "@bull-board/fastify": "^5.23.0",
    "@bull-board/ui": "^5.23.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@nexor/shared": "workspace:*",
    "@prisma/client": "^6.3.0",
    "@sentry/node": "^10.44.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.0",
    "exceljs": "^4.4.0",
    "fastify": "^4.29.0",
    "fastify-plugin": "^4.5.1",
    "googleapis": "^171.4.0",
    "resend": "^6.12.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.9",
    "prisma": "^6.3.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
