# =============================================================================
# NEXOR — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitear el archivo .env — solo este .env.example.
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS (PostgreSQL)
# -----------------------------------------------------------------------------

# URL de conexion a PostgreSQL — ROL nexor_app (no-superuser, subject to RLS).
# Usado por el servidor Fastify en runtime. RLS se aplica a todas las queries.
#
# ANTES DE USAR: ejecutar scripts/setup-db-user.sh para crear el rol nexor_app.
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Opcion 1 — Docker Compose incluido en el repo (puerto 5433):
#   docker-compose up -d && ./scripts/setup-db-user.sh
DATABASE_URL="postgresql://nexor_app:nexor_app_secret@localhost:5433/nexor_dev"

# URL directa para migraciones Prisma y seeds — ROL postgres (superuser, bypassa RLS).
# Usado por: prisma migrate dev/deploy, npx tsx prisma/seed*.ts
DIRECT_DATABASE_URL="postgresql://postgres:password@localhost:5433/nexor_dev"

# -----------------------------------------------------------------------------
# REDIS (BullMQ + cache)
# -----------------------------------------------------------------------------

# URL de conexion a Redis.
# En desarrollo local puedes usar Redis instalado localmente o un servicio como Upstash.
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# JWT (Autenticacion)
# -----------------------------------------------------------------------------

# Clave secreta para firmar los tokens JWT.
# Debe ser una cadena aleatoria larga y segura. Nunca reutilizar entre entornos.
# Genera una con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="cambia_esto_por_un_secreto_seguro_de_al_menos_64_caracteres"

# Duracion del token JWT. Ejemplos: "7d", "24h", "1h"
JWT_EXPIRES_IN="7d"

# Vigencia del refresh token en dias. Minimo 30 dias (requerido por HU-004).
REFRESH_TOKEN_EXPIRES_DAYS=30

# -----------------------------------------------------------------------------
# API (Backend Fastify)
# -----------------------------------------------------------------------------

# Puerto donde levanta el servidor de la API.
# El frontend espera que la API este en este puerto.
PORT=3001

# Host donde escucha el servidor. En produccion usar 0.0.0.0.
HOST="0.0.0.0"

# Nivel de logs: trace | debug | info | warn | error | fatal
LOG_LEVEL="info"

# Ambiente de ejecucion: development | test | production
NODE_ENV="development"

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# URL del frontend permitida para hacer requests a la API.
# En desarrollo: http://localhost:3000
# En produccion: https://app.nexor.co (o el dominio real)
CORS_ORIGIN="http://localhost:3000"

# Maximo de requests permitidos por minuto por empresa (HU-005 rate limiting por tenant).
RATE_LIMIT_MAX=100

# -----------------------------------------------------------------------------
# CLAUDE API (Anthropic — Agentes de IA)
# -----------------------------------------------------------------------------

# Clave de API de Anthropic para usar Claude.
# Obtenla en: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# Modelo de Claude a usar para los agentes.
# Consultar README_AGENTS.md para la lista de modelos soportados.
CLAUDE_MODEL="claude-opus-4-5"

# Maximo de turnos permitidos por ejecucion del agente (evita bucles infinitos).
AGENT_MAX_TURNS=10

# -----------------------------------------------------------------------------
# WHATSAPP (Meta Business API)
# -----------------------------------------------------------------------------

# Token de acceso permanente de la cuenta de Meta Business.
# Obtenlo en: https://developers.facebook.com/
WHATSAPP_ACCESS_TOKEN="EAAxxxxx..."

# Clave de verificacion del webhook de WhatsApp.
# Debe coincidir con la configurada en el dashboard de Meta.
WHATSAPP_VERIFY_TOKEN="nexor_webhook_verify_token"

# Secreto de la app de Meta para verificar la firma HMAC de los webhooks.
WHATSAPP_APP_SECRET="meta_app_secret"

# -----------------------------------------------------------------------------
# GMAIL (Google OAuth)
# -----------------------------------------------------------------------------

# Client ID de la app OAuth de Google.
# Obtenlo en: https://console.cloud.google.com/
GOOGLE_CLIENT_ID="xxxxx.apps.googleusercontent.com"

# Client Secret de la app OAuth de Google.
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxx"

# URL de redireccion OAuth. Debe estar registrada en Google Cloud Console.
GOOGLE_REDIRECT_URI="http://localhost:3001/auth/google/callback"

# -----------------------------------------------------------------------------
# CIFRADO (tokens de integracion)
# -----------------------------------------------------------------------------

# Clave de 32 bytes para cifrar los tokens de integracion en la DB con AES-256.
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="cambia_esto_por_32_bytes_hex_seguros_64_chars"

# -----------------------------------------------------------------------------
# EMAIL (Resend)
# -----------------------------------------------------------------------------

# API key de Resend para envio de emails transaccionales.
# Obtenla en: https://resend.com/
RESEND_API_KEY="re_xxxxx..."

# Direccion remitente de los emails enviados por el sistema.
EMAIL_FROM="NEXOR <no-reply@nexor.co>"

# -----------------------------------------------------------------------------
# MONITOREO (Sentry)
# -----------------------------------------------------------------------------

# DSN de Sentry para reportar errores en tiempo real.
# Obtenlo en: https://sentry.io/ (opcional en desarrollo)
SENTRY_DSN=""

# -----------------------------------------------------------------------------
# FRONTEND (Next.js)
# Solo las variables prefijadas con NEXT_PUBLIC_ son accesibles en el navegador.
# -----------------------------------------------------------------------------

# URL base de la API del backend. El frontend la usa para hacer requests.
NEXT_PUBLIC_API_URL="http://localhost:3001"
