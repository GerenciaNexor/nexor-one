{
  "name": "nexor",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test:e2e":        "pnpm --filter @nexor/e2e test",
    "test:e2e:headed": "pnpm --filter @nexor/e2e test:headed",
    "test:e2e:report": "pnpm --filter @nexor/e2e report",
    "clean": "turbo clean && find . -name 'dist' -not -path '*/node_modules/*' -type d -exec rm -rf {} + 2>/dev/null; true"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "exceljs": "^4.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "unrs-resolver"
    ]
  }
}
